# ==============================================================================
# Salad Fleet Manager Environment Configuration
# ==============================================================================

# --- Option A: Single Account Setup (Simpler) ---
# If you only have one Salad Cloud account, use these environment variables.
SALAD_API_KEY=YOUR_SALAD_API_KEY_HERE
SALAD_ACCOUNT_NAME=my-account
SALAD_PROJECTS=my-organization/my-project

# --- Option B: Multi-Account Setup ---
# If you have multiple Salad Cloud accounts, uncomment and define them like below.
# You can add as many as you need (1, 2, 3...).
# Note: Multi-account setup takes precedence over Single Account Setup if defined.

# SALAD_ACCOUNT_1_NAME=account-1
# SALAD_ACCOUNT_1_API_KEY=YOUR_SALAD_API_KEY_1
# SALAD_ACCOUNT_1_ORGS=org-1/project-1,org-1/project-2

# SALAD_ACCOUNT_2_NAME=account-2
# SALAD_ACCOUNT_2_API_KEY=YOUR_SALAD_API_KEY_2
# SALAD_ACCOUNT_2_ORGS=org-2/project-3
